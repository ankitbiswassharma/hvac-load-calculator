# --------------------------------------------------------------
# Production .env for hvac.muskit.in (Hostinger VPS KVM 2)
# Copy to .env, fill in values, then:  docker compose up -d
# --------------------------------------------------------------

# Runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Absolute base URL used for outbound links (emails, payment redirects, AI
# narratives). Always include scheme + host, no trailing slash.
APP_BASE_URL=https://hvac.muskit.in

# Cookies — keep "1" in production behind TLS termination.
SESSION_COOKIE_SECURE=1

# Required only when this repo starts its own Traefik edge with
# docker-compose.traefik.yml.
TRAEFIK_CERT_EMAIL=admin@muskit.in

# --------------------------------------------------------------
# Postgres
# --------------------------------------------------------------
POSTGRES_USER=hvac
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=hvac
# Inside docker compose, the host is the service name "db"
DATABASE_URL=postgres://hvac:CHANGE_ME_strong_password@db:5432/hvac

# --------------------------------------------------------------
# OpenAI (optional — enables AI advisor + AI design narration)
# --------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini

# --------------------------------------------------------------
# SMTP (optional — used for account & license emails)
# --------------------------------------------------------------
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_USER=noreply@muskit.in
# SMTP_PASS=
# SMTP_FROM="Musk-IT HVAC <noreply@muskit.in>"

# --------------------------------------------------------------
# Razorpay (optional — license + payment links)
# --------------------------------------------------------------
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
